{
  "$schema": "https://raw.githubusercontent.com/nicedoc/ohmyschema/main/schemas/tauri/2.0/config.schema.json",
  "productName": "intsoc-transactor",
  "version": "0.1.0",
  "identifier": "org.hyperpolymath.intsoc-transactor",
  "build": {
    "frontendDist": "../",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "intsoc-transactor - Internet Society Document Processing",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com; style-src 'self' 'unsafe-inline'"
    }
  },
  "plugins": {
    "shell": {
      "scope": [
        {
          "name": "idnits",
          "cmd": "idnits",
          "args": true
        },
        {
          "name": "xml2rfc",
          "cmd": "xml2rfc",
          "args": true
        }
      ]
    }
  }
}
